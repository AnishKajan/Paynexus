# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Copy to frontend/.env.local and fill in your Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# The canonical public URL of this deployment.
# Local dev:  http://localhost:3000
# Vercel:     https://<your-project>.vercel.app  (set in Vercel project env vars)
#
# This MUST match the "Site URL" in Supabase Auth Settings.
# The value <NEXT_PUBLIC_SITE_URL>/auth/callback must be in Supabase Redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Backend (Rust/Axum) ───────────────────────────────────────────────────────
# Copy to backend/.env and fill in your Supabase project values.
# JWT secret: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=<your-jwt-secret>
SUPABASE_PROJECT_URL=https://<your-ref>.supabase.co
